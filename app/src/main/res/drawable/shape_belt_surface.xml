<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#8B7D6B"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
<item android:top="1dp" android:start="2dp" android:end="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#9C8E7C"/>
            <corners android:radius="3dp"/>
        </shape>
    </item>
<item android:top="12dp" android:bottom="12dp" android:start="6dp" android:end="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="0.5dp" android:color="#6D6055" android:dashWidth="4dp" android:dashGap="8dp"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
</layer-list>
