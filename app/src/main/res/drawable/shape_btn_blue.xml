<?xml version="1.0" encoding="utf-8"?>
<!-- Blue 3D button (chip_blue) — English version of shape_btn_green. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#1E3A4A"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
<item android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#5BA0CC"
                android:endColor="#3D86B5"
                android:angle="270"/>
            <corners android:radius="20dp"/>
            <stroke android:width="1dp" android:color="#2C6489"/>
        </shape>
    </item>
<item android:bottom="6dp" android:top="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#A8CEE0"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
