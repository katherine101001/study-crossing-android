<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#2E4A1C"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
<item android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6DA04A"
                android:endColor="#5B8C3E"
                android:angle="270"/>
            <corners android:radius="20dp"/>
            <stroke android:width="1dp" android:color="#3A5B22"/>
        </shape>
    </item>
<item android:bottom="6dp" android:top="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#8DC46A"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
