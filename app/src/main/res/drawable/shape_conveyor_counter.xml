<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6D4C41"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item android:bottom="2dp" android:start="2dp" android:end="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#A1887F"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item android:bottom="2dp" android:start="4dp" android:end="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#D7CCC8"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
<item android:bottom="2dp" android:top="8dp" android:start="10dp" android:end="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/my_green"/>
            <corners android:radius="0dp"/>
        </shape>
    </item>
</layer-list>
