<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5D4037"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:top="4dp" android:bottom="4dp" android:start="4dp" android:end="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFBE9"/>
            <corners android:radius="14dp"/>
            <stroke android:width="2dp" android:color="#F9A825"/>
        </shape>
    </item>
    <item android:top="8dp" android:bottom="8dp" android:start="8dp" android:end="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="0.8dp" android:color="#E8D4A0"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>
