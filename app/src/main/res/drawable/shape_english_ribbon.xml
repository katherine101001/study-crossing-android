<?xml version="1.0" encoding="utf-8"?>
<!-- English subject ribbon — blue (chip_blue), matches shape_math_ribbon / shape_gk_ribbon pattern. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#1E3A4A"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
<item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#5BA0CC"
                android:endColor="#3D86B5"
                android:angle="270"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#2C6489"/>
        </shape>
    </item>
<item android:bottom="4dp" android:top="2dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#A8CEE0"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
