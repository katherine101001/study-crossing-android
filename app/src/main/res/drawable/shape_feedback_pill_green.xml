<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3D6B2E"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6DA04A"
                android:endColor="#5B8C3E"
                android:angle="270"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#8DC46A"/>
        </shape>
    </item>
</layer-list>
