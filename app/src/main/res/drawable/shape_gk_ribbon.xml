<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#36225C"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
<item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#9B7AD9"
                android:endColor="#7E57C2"
                android:angle="270"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#5A3A99"/>
        </shape>
    </item>
<item android:bottom="4dp" android:top="2dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#B39DDB"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
