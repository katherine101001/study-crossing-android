<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#7E4F26"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#D89A4F"
                android:endColor="#A87836"
                android:type="radial"
                android:gradientRadius="80dp"/>
            <stroke android:width="2.5dp" android:color="#F0CE85"/>
        </shape>
    </item>
</layer-list>
