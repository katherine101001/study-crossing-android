<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2E4A1C"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:top="3dp" android:bottom="3dp" android:start="3dp" android:end="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6DA04A"
                android:endColor="#5B8C3E"
                android:angle="270"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#3A5B22"/>
        </shape>
    </item>
</layer-list>
