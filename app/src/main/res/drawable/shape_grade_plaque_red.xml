<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5C1E14"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:top="3dp" android:bottom="3dp" android:start="3dp" android:end="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#C25040"
                android:endColor="#A33A2D"
                android:angle="270"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#7E2B1F"/>
        </shape>
    </item>
</layer-list>
