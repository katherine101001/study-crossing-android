<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#2E4A1C"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
<item android:bottom="4dp" android:start="2dp" android:end="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_yellow"/>
            <corners android:radius="14dp"/>
            <stroke android:width="3dp" android:color="@color/my_green"/>
        </shape>
    </item>
<item android:bottom="4dp" android:top="3dp" android:left="5dp" android:right="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#8DC46A"/>
            <corners android:radius="11dp"/>
        </shape>
    </item>
</layer-list>
