<?xml version="1.0" encoding="utf-8"?>
<!-- Amber pill for "SOON" / coming-soon badges. Warm, optimistic tone -
     reads as "in progress" without alarming the user. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6B4423"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E0A85F"
                android:endColor="#C0883C"
                android:angle="270"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#8A5A26"/>
        </shape>
    </item>
</layer-list>
