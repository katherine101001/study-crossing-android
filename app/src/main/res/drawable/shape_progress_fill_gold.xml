<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6DA04A"
                android:endColor="#5B8C3E"
                android:angle="270"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item android:top="1dp" android:bottom="3dp" android:start="2dp" android:end="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="0.8dp" android:color="#A8D384"/>
            <corners android:radius="5dp"/>
        </shape>
    </item>
</layer-list>
