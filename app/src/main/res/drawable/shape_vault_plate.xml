<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3D2817"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#D9A85C"
                android:endColor="#A87836"
                android:angle="270"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#6B4423"/>
        </shape>
    </item>
    <item android:bottom="3dp" android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="0.8dp" android:color="#F0CE85"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
