<?xml version="1.0" encoding="utf-8"?>
<!-- 3D field-guide word stamp — cream paper face with blue postal border.
     English subject color is blue (chip_blue), so the word tags follow it. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#1E3A4A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
<item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFBE9"
                android:endColor="#F5E6BA"
                android:angle="270"/>
            <corners android:radius="12dp"/>
            <stroke android:width="2dp" android:color="@color/chip_blue"/>
        </shape>
    </item>
<item android:bottom="3dp" android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <stroke android:width="1dp" android:color="#A8CEE0"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>
