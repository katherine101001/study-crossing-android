<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<item>
        <shape android:shape="rectangle">
            <solid android:color="#1A000000"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
<item android:bottom="2dp" android:start="1dp" android:end="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFDF5"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1.5dp" android:color="#A1887F"/>
        </shape>
    </item>
<item android:bottom="2dp" android:top="8dp" android:start="8dp" android:end="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF"/>
            <corners android:radius="6dp"/>
            <stroke android:width="0.5dp" android:color="#8D6E63"/>
        </shape>
    </item>
</layer-list>
