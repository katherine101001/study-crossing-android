<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_grass_tiled">

    <!-- 主界面: toolbar + welcome区 + 3个学科建筑 + 底部快捷入口 -->

    <LinearLayout
        android:id="@+id/app_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_green"
        android:elevation="3dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_main"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/my_green"
        app:popupTheme="@style/PopupMenu.Themed"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/shape_btn_icon_badge"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_building_tent"
                    android:scaleType="fitCenter">
                </ImageView>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WELCOME HOME"
                    android:textSize="9dp"
                    android:textStyle="bold"
                    android:textColor="#E8F5E9"
                    android:letterSpacing="0.22"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Island Square"
                    android:textSize="19dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/deep_wood">
    </View>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/ll_profile_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_paper_card"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="5dp">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_avatar_cat"
                        android:scaleType="fitCenter"
                        android:padding="4dp">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HELLO ISLANDER"
                        android:textSize="9dp"
                        android:textStyle="bold"
                        android:textColor="@color/wood_brown"
                        android:letterSpacing="0.22"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome to your island!"
                        android:textSize="17dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to edit your profile ›"
                        android:textSize="11dp"
                        android:textStyle="bold"
                        android:textColor="@color/my_green"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/shape_rounded_yellow"
                    android:paddingStart="10dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:elevation="3dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_coin_bell"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="6dp">
                    </ImageView>

                    <TextView
                        android:id="@+id/tv_coins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="18dp"></View>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_pin_yellow"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pick Your Activity"
                    android:textSize="15dp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_wood"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@color/wood_brown">
                </View>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"></View>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/shape_building_plot"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:src="@drawable/ic_building_math"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MATH"
                            android:textSize="9dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.18"
                            android:fontFamily="@font/fredoka_bold"
                            android:background="@drawable/shape_subject_chip_math"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:layout_gravity="top|end">
                        </TextView>

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vault Site"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:gravity="center"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_npc_tanuki_normal"
                            android:scaleType="fitCenter"
                            android:background="@drawable/shape_avatar_circle"
                            android:padding="2dp"
                            android:layout_marginEnd="6dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tom Nook"
                            android:textSize="11dp"
                            android:textColor="@color/wood_brown"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btn_math_building"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp"
                        android:background="@drawable/sel_btn_green">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Play"
                            android:textSize="15dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/shape_building_plot"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:src="@drawable/ic_building_english"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ENGLISH"
                            android:textSize="9dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.18"
                            android:fontFamily="@font/fredoka_bold"
                            android:background="@drawable/shape_subject_chip_english"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:layout_gravity="top|end">
                        </TextView>

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Post Office"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:gravity="center"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_npc_isabelle_happy"
                            android:scaleType="fitCenter"
                            android:background="@drawable/shape_avatar_circle"
                            android:padding="2dp"
                            android:layout_marginEnd="6dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Isabelle"
                            android:textSize="11dp"
                            android:textColor="@color/wood_brown"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btn_english_building"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp"
                        android:background="@drawable/sel_btn_green">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Play"
                            android:textSize="15dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_building_plot"
                android:padding="14dp"
                android:elevation="4dp"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_building_museum"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GENERAL KNOWLEDGE"
                        android:textSize="9dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:letterSpacing="0.18"
                        android:fontFamily="@font/fredoka_bold"
                        android:background="@drawable/shape_subject_chip_gk"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp">
                    </TextView>

                    <View android:layout_width="match_parent" android:layout_height="6dp"></View>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Museum"
                        android:textSize="17dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_npc_owl_angry"
                            android:scaleType="fitCenter"
                            android:background="@drawable/shape_avatar_circle"
                            android:padding="2dp"
                            android:layout_marginEnd="6dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blathers · Fossil Dig"
                            android:textSize="12dp"
                            android:textColor="@color/wood_brown"
                            android:fontFamily="@font/nunito_bold">
                        </TextView>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btn_gk_building"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp"
                        android:background="@drawable/sel_btn_green">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Play"
                            android:textSize="15dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_pin_red"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your History"
                    android:textSize="15dp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_wood"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@color/wood_brown">
                </View>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="10dp"></View>

            <LinearLayout
                android:id="@+id/ll_notice_board"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="5dp"
                android:background="@drawable/sel_btn_brown">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/shape_btn_icon_badge"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_pin_red"
                        android:scaleType="fitCenter"
                        android:rotation="-12">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/btn_notice_board"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notice Board"
                        android:textSize="17dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finished quests"
                        android:textSize="11dp"
                        android:textColor="#FFE0B2"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="10dp"></View>

            <LinearLayout
                android:id="@+id/ll_quest_archive"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="5dp"
                android:background="@drawable/sel_btn_green">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/shape_btn_icon_badge"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_stamp_done"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Quests"
                        android:textSize="17dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Replay anytime"
                        android:textSize="11dp"
                        android:textColor="#DCEDC8"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
