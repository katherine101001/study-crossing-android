<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reward_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream_paper">

    <LinearLayout
        android:id="@+id/app_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_green"
        android:elevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/shape_btn_icon_badge"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_grade_star"
                    android:scaleType="fitCenter">
                </ImageView>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUEST COMPLETE"
                    android:textSize="9dp"
                    android:textStyle="bold"
                    android:textColor="#E8F5E9"
                    android:letterSpacing="0.22"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resident Services"
                    android:textSize="19dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_grade_star"
                android:scaleType="fitCenter">
            </ImageView>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/deep_wood">
        </View>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_wood_plaque"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"
                android:layout_gravity="center_horizontal"
                android:elevation="4dp"
                android:layout_marginBottom="-8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_postage_stamp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOOK INC.  ·  REPORT"
                    android:textSize="11dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.18"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <!-- paper card用wrap_content自然高度, 内容从上往下排, 不再拉伸居中 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/shape_paper_card"
                android:padding="16dp"
                android:paddingTop="20dp"
                android:elevation="6dp"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/shape_avatar_circle"
                        android:layout_marginTop="4dp"
                        android:elevation="6dp">

                        <ImageView
                            android:id="@+id/iv_tom_nook"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_npc_tanuki_normal"
                            android:scaleType="fitCenter"
                            android:padding="4dp">
                        </ImageView>

                    </FrameLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_bubble_tail_left"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="-4dp"
                        android:elevation="3dp">
                    </ImageView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/shape_dialogue_bubble"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="11dp"
                        android:elevation="5dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tom Nook says..."
                            android:textSize="9dp"
                            android:textStyle="bold"
                            android:textColor="@color/wood_brown"
                            android:letterSpacing="0.08"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                        <TextView
                            android:id="@+id/tv_npc_dialogue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Excellent work, islander!"
                            android:textSize="12dp"
                            android:textStyle="bold"
                            android:textColor="@color/deep_wood"
                            android:layout_marginTop="1dp"
                            android:fontFamily="@font/nunito_bold">
                        </TextView>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/cork_tan"
                    android:alpha="0.5"
                    android:layout_marginBottom="14dp">
                </View>

                <TextView
                    android:id="@+id/tv_result_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESULT GRADE"
                    android:textSize="10dp"
                    android:textStyle="bold"
                    android:textColor="@color/wood_brown"
                    android:letterSpacing="0.22"
                    android:fontFamily="@font/fredoka_bold"
                    android:layout_marginBottom="10dp">
                </TextView>

                <FrameLayout
                    android:id="@+id/fl_grade_halo"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/shape_grade_halo"
                    android:elevation="4dp">

                    <ImageView
                        android:id="@+id/iv_grade"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_grade_a"
                        android:scaleType="fitCenter"
                        android:padding="18dp">
                    </ImageView>

                    <TextView
                        android:id="@+id/tv_grade_letter"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:text="B"
                        android:textSize="56dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/shape_grade_badge_b"
                        android:elevation="2dp"
                        android:shadowColor="#88000000"
                        android:shadowDx="0"
                        android:shadowDy="3"
                        android:shadowRadius="4"
                        android:visibility="gone"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grade: A"
                    android:textSize="14dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.10"
                    android:fontFamily="@font/fredoka_bold"
                    android:background="@drawable/shape_grade_plaque_green"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="8dp"
                    android:elevation="3dp"
                    android:layout_marginTop="10dp">
                </TextView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/cork_tan"
                    android:alpha="0.5"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp">
                </View>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/shape_rounded_yellow"
                    android:paddingStart="14dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/ic_coin_bag"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="10dp">
                    </ImageView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REWARD"
                            android:textSize="9dp"
                            android:textStyle="bold"
                            android:textColor="@color/wood_brown"
                            android:letterSpacing="0.22"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                        <TextView
                            android:id="@+id/tv_coins_earned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="800 Coins"
                            android:textSize="22dp"
                            android:textStyle="bold"
                            android:textColor="@color/my_green"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— Signed, Tom Nook"
                    android:textSize="12dp"
                    android:textStyle="italic"
                    android:textColor="@color/cork_tan"
                    android:fontFamily="@font/patrick_hand"
                    android:layout_marginTop="10dp"
                    android:layout_gravity="end">
                </TextView>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp"></View>

            <LinearLayout
                android:id="@+id/ll_back_hub_wrapper"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="5dp"
                android:background="@drawable/sel_btn_green">

                <FrameLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/shape_btn_icon_badge"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chevron_white"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <TextView
                    android:id="@+id/btn_back_hub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back to Island"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="10dp"></View>

            <LinearLayout
                android:id="@+id/btn_share_wrapper"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="5dp"
                android:background="@drawable/sel_btn_brown">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_share_envelope"
                    android:scaleType="fitCenter">
                </ImageView>

                <TextView
                    android:id="@+id/btn_share"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mail to a Friend"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
