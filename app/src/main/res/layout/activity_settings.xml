<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_archive_planks">

    <LinearLayout
        android:id="@+id/app_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_green"
        android:elevation="3dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_settings"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/my_green"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_back_chevron"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    android:background="@drawable/shape_btn_icon_badge"
                    android:layout_marginEnd="10dp">
                </ImageView>

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="12dp"
                    android:elevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_npc_isabelle_happy"
                        android:scaleType="fitCenter"
                        android:padding="3dp">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESIDENT SERVICES"
                        android:textSize="9dp"
                        android:textStyle="bold"
                        android:textColor="#DCEDC8"
                        android:letterSpacing="0.22"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="19dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                </LinearLayout>

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/deep_wood">
        </View>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginTop="6dp"
                    android:elevation="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_npc_isabelle_happy"
                        android:scaleType="fitCenter"
                        android:padding="4dp">
                    </ImageView>

                </FrameLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_bubble_tail_left"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="-4dp"
                    android:elevation="3dp">
                </ImageView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/shape_dialogue_bubble"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="11dp"
                    android:elevation="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Isabelle says..."
                        android:textSize="9dp"
                        android:textStyle="bold"
                        android:textColor="@color/wood_brown"
                        android:letterSpacing="0.08"
                        android:fontFamily="@font/fredoka_bold">
                    </TextView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome to the Town Hall! How can I help today?"
                        android:textSize="12dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:layout_marginTop="1dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_section_plaque"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="7dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_pin_yellow"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_edit_profile"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/shape_paper_card"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="14dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_id_tag"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit Profile"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name and avatar"
                        android:textSize="11dp"
                        android:textColor="@color/wood_brown"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit  ›"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/shape_pill_green"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="7dp"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_section_plaque"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="7dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_pin_green"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gameplay"
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_music_toggle"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/shape_paper_card"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_coin_bell"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Music"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Island tunes"
                        android:textSize="11dp"
                        android:textColor="@color/wood_brown"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_music_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOON"
                    android:textSize="11dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/shape_pill_amber"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="7dp"
                    android:letterSpacing="0.16"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_reset_progress"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/shape_paper_card"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="14dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_confirm_glove"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reset Progress"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear all quest data"
                        android:textSize="11dp"
                        android:textColor="@color/wood_brown"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/shape_pill_red"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="7dp"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_section_plaque"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="7dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_pin_blue"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_credits"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/shape_paper_card"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_brush_hint"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Credits"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team and assets"
                        android:textSize="11dp"
                        android:textColor="@color/wood_brown"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View  ›"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/shape_pill_green"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="7dp"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_app_version"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/shape_paper_card"
                android:elevation="3dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_avatar_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_package_small"
                        android:scaleType="fitCenter">
                    </ImageView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Version"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/deep_wood"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Study Crossing"
                        android:textSize="11dp"
                        android:textColor="@color/wood_brown"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0.0"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_wood"
                    android:background="@drawable/shape_value_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="7dp"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp"
                android:background="@drawable/sel_btn_brown"
                android:layout_marginTop="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_btn_back"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="10dp">
                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log Out"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="◇ Made with love on the Island ◇"
                android:textSize="11dp"
                android:textColor="#DCEDC8"
                android:gravity="center"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.1"
                android:fontFamily="@font/fredoka_bold">
            </TextView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
