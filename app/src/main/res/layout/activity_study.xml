<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/study_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_image"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/app_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/chip_red"
        android:elevation="3dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_study"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/chip_red"
        app:contentInsetStartWithNavigation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="16dp">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/shape_avatar_circle"
                android:layout_marginEnd="10dp"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/iv_toolbar_subject"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_npc_tanuki_normal"
                    android:scaleType="fitCenter"
                    android:padding="3dp">
                </ImageView>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_toolbar_subject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MATH QUEST"
                    android:textSize="9dp"
                    android:textStyle="bold"
                    android:textColor="#FFE0B2"
                    android:letterSpacing="0.22"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

                <TextView
                    android:id="@+id/tv_toolbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vault Challenge"
                    android:textSize="19dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_apples"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_apple_1"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_hp_apple"
                    android:scaleType="fitCenter">
                </ImageView>

                <ImageView
                    android:id="@+id/iv_apple_2"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_hp_apple"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="2dp">
                </ImageView>

                <ImageView
                    android:id="@+id/iv_apple_3"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_hp_apple"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="2dp">
                </ImageView>

                <TextView
                    android:id="@+id/tv_toolbar_apples"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="x3"
                    android:textSize="14dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <View
        android:id="@+id/trim_study"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/deep_wood">
    </View>

    </LinearLayout>
<FrameLayout
        android:id="@+id/container_top"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">
    </FrameLayout>
<LinearLayout
        android:id="@+id/btn_start_challenge"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp"
        android:background="@drawable/sel_btn_green">

        <ImageView
            android:id="@+id/iv_challenge_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_stamp_confirm"
            android:scaleType="fitCenter"
            android:layout_marginEnd="10dp">
        </ImageView>

        <TextView
            android:id="@+id/btn_challenge_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Blueprint"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/fredoka_bold">
        </TextView>

    </LinearLayout>
<View
        android:id="@+id/divider_study"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/deep_wood"
        android:visibility="gone">
    </View>

    <FrameLayout
        android:id="@+id/container_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false">
    </FrameLayout>

</LinearLayout>
