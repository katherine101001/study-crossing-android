<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/top_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- TopFragment: NPC全身像 + 对话气泡 + lesson面板(按subject切换) -->

    <!-- NPC area: NPC drawable 180x230dp, container留20dp clearance就够了 -->
    <!-- 240dp比260dp省20dp给下面lesson + bottom fragment -->
    <FrameLayout
        android:id="@+id/fl_npc_area"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:paddingTop="6dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="10dp">
<FrameLayout
            android:id="@+id/ll_dialogue_card"
            android:layout_width="316dp"
            android:layout_height="wrap_content"
            android:layout_gravity="start|bottom"
            android:layout_marginStart="28dp"
            android:layout_marginBottom="-8dp"
            android:elevation="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_speech_bubble_filled"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true">
            </ImageView>
<LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="14dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/shape_npc_name_tag"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="5dp"
                android:elevation="10dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_grade_star"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="5dp">
                </ImageView>

                <TextView
                    android:id="@+id/tv_npc_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Isabelle"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_wood"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="34dp"
                android:paddingEnd="34dp"
                android:paddingTop="34dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tv_dialogue"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:fontFamily="@font/nunito_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="Let me teach you something today!"
                    android:textColor="@color/ink_brown"
                    android:textSize="13dp"
                    android:textStyle="bold"></TextView>

            </LinearLayout>

        </FrameLayout>
<ImageView
            android:id="@+id/iv_npc_fullbody"
            android:layout_width="180dp"
            android:layout_height="230dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="-10dp"
            android:layout_marginBottom="-10dp"
            android:src="@drawable/ic_npc_squirrel_normal_fullbody"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true">
        </ImageView>

    </FrameLayout>

    <!-- spacer之前20dp太占空间, 6dp又太挤, 12dp平衡一点 -->
    <View android:layout_width="match_parent" android:layout_height="12dp"></View>

    <LinearLayout
        android:id="@+id/ll_math_blueprint"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
<FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/shape_cork_board"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">
<FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/shape_math_ribbon"
                    android:elevation="4dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/ic_math_scroll"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="8dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BLUEPRINT"
                            android:textSize="12dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.12"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </FrameLayout>

                <!-- image weight=1.3, padding=5dp把frame边框露出来 -->
                <!-- image/video包在CardView里, cornerRadius裁圆角, frame外框还在 -->
                <FrameLayout
                    android:id="@+id/fl_math_image_area"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/shape_math_frame"
                    android:elevation="3dp"
                    android:padding="5dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageView
                            android:id="@+id/iv_math_display"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_math_blueprint"
                            android:scaleType="centerCrop">
                        </ImageView>

                        <!-- video优先, 有video就播这个盖住image -->
                        <VideoView
                            android:id="@+id/vv_math_display"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">
                        </VideoView>

                    </androidx.cardview.widget.CardView>

                </FrameLayout>
<ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/tv_math_lesson"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="[ Blueprint content ]"
                        android:textSize="14dp"
                        android:textColor="@color/ink_brown"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </ScrollView>

            </LinearLayout>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_red"
                android:scaleType="fitCenter"
                android:layout_gravity="top|start"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:rotation="-15"
                android:elevation="4dp">
            </ImageView>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_red"
                android:scaleType="fitCenter"
                android:layout_gravity="top|end"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="10dp"
                android:rotation="12"
                android:elevation="4dp">
            </ImageView>

        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_english_manual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
<FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/shape_cork_board"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">
<FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/shape_english_ribbon"
                    android:elevation="4dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/ic_postage_stamp"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="8dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FIELD GUIDE"
                            android:textSize="12dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.12"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </FrameLayout>

                <!-- english frame一样, padding露出边框, CardView负责裁image/video圆角 -->
                <FrameLayout
                    android:id="@+id/fl_english_image_area"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/shape_handbook_frame_blue"
                    android:elevation="3dp"
                    android:padding="5dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageView
                            android:id="@+id/iv_handbook"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_post_handbook_open"
                            android:scaleType="centerCrop">
                    </ImageView>

                        <!-- english lesson也可以放video -->
                        <VideoView
                            android:id="@+id/vv_handbook"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">
                        </VideoView>

                    </androidx.cardview.widget.CardView>

                </FrameLayout>
<ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/tv_english_lesson"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="[ Manual content ]"
                        android:textSize="14dp"
                        android:textColor="@color/ink_brown"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </ScrollView>

            </LinearLayout>
<ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_red"
                android:scaleType="fitCenter"
                android:layout_gravity="top|start"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:rotation="-15"
                android:elevation="4dp">
            </ImageView>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_green"
                android:scaleType="fitCenter"
                android:layout_gravity="top|end"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="10dp"
                android:rotation="12"
                android:elevation="4dp">
            </ImageView>

        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/fl_gk_projector"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
<FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/shape_cork_board"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">
<FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/shape_gk_ribbon"
                    android:elevation="4dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/ic_grade_star"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="8dp">
                        </ImageView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FIELD NOTES"
                            android:textSize="12dp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.12"
                            android:fontFamily="@font/fredoka_bold">
                        </TextView>

                    </LinearLayout>

                </FrameLayout>

                <!-- GK frame一样, padding露边框, CardView裁image/video圆角 -->
                <FrameLayout
                    android:id="@+id/fl_gk_image_area"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/shape_gk_frame"
                    android:elevation="3dp"
                    android:padding="5dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageView
                            android:id="@+id/iv_gk_display"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_gk_fossil"
                            android:scaleType="centerCrop">
                        </ImageView>

                        <!-- GK quest里很多cultural video (kompang, monument那些) -->
                        <VideoView
                            android:id="@+id/vv_gk_display"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">
                        </VideoView>

                    </androidx.cardview.widget.CardView>

                </FrameLayout>
<ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/tv_gk_lesson"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="[ Field notes content ]"
                        android:textSize="14dp"
                        android:textColor="@color/ink_brown"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:fontFamily="@font/nunito_bold">
                    </TextView>

                </ScrollView>

            </LinearLayout>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_purple"
                android:scaleType="fitCenter"
                android:layout_gravity="top|start"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:rotation="-15"
                android:elevation="4dp">
            </ImageView>

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/shape_pin_purple"
                android:scaleType="fitCenter"
                android:layout_gravity="top|end"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="10dp"
                android:rotation="12"
                android:elevation="4dp">
            </ImageView>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
