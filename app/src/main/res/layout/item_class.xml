<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cream_paper">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_paper"
        android:minHeight="78dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/fl_class_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/shape_avatar_circle"
            android:layout_marginStart="16dp"
            android:elevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_id_tag"
                android:padding="12dp">
            </ImageView>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_class_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Class name"
            android:textSize="17dp"
            android:textStyle="bold"
            android:textColor="@color/deep_wood"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="86dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="60dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_class_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 students"
            android:textSize="12dp"
            android:textColor="@color/wood_brown"
            android:layout_marginStart="86dp"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_class_name"
            app:layout_constraintStart_toStartOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_chevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="30dp"
            android:textStyle="bold"
            android:textColor="@color/cork_tan"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
