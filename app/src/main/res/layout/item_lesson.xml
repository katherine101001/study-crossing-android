<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cream_paper">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_paper"
        android:minHeight="104dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:id="@+id/fl_lesson_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/shape_avatar_circle"
            android:layout_marginStart="16dp"
            android:elevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_subject_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_npc_tanuki_normal"
                android:padding="4dp">
            </ImageView>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_lesson_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Lesson title here"
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/deep_wood"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:layout_marginStart="104dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_lesson_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Lesson description goes here for the admin to read."
            android:textSize="11dp"
            android:textColor="@color/wood_brown"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="104dp"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_lesson_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_lesson_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Math"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.14"
            android:background="@drawable/shape_subject_chip_math"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="104dp"
            android:layout_marginTop="7dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_lesson_desc"
            app:layout_constraintStart_toStartOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_chevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="30dp"
            android:textStyle="bold"
            android:textColor="@color/cork_tan"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
