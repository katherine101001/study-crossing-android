<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardBackgroundColor="@color/cream_paper"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#A1887F"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/fl_subject_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/shape_avatar_circle"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/iv_subject_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_npc_tanuki_normal"
                android:scaleType="fitCenter"
                android:padding="3dp">
            </ImageView>

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_session_subject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MATH"
                android:textSize="9dp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.18"
                android:background="@drawable/shape_subject_chip_math"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:fontFamily="@font/fredoka_bold">
            </TextView>

            <View android:layout_width="match_parent" android:layout_height="4dp"></View>

            <TextView
                android:id="@+id/tv_session_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cracked the vault code"
                android:textSize="16dp"
                android:textStyle="bold"
                android:textColor="@color/deep_wood"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_bold">
            </TextView>

            <View android:layout_width="match_parent" android:layout_height="3dp"></View>

            <LinearLayout
                android:id="@+id/ll_coins_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_coin_bell"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="4dp">
                </ImageView>

                <TextView
                    android:id="@+id/tv_session_coins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="950 Coins"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/my_green"
                    android:fontFamily="@font/fredoka_bold">
                </TextView>

            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/fl_grade_box"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/shape_grade_halo"
            android:layout_marginStart="8dp"
            android:elevation="3dp">

            <TextView
                android:id="@+id/tv_session_grade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A"
                android:textSize="24dp"
                android:textStyle="bold"
                android:textColor="@color/deep_wood"
                android:gravity="center"
                android:fontFamily="@font/fredoka_bold">
            </TextView>

        </FrameLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
