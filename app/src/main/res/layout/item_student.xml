<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cream_paper">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_paper"
        android:minHeight="92dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/fl_student_avatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/shape_avatar_circle"
            android:layout_marginStart="16dp"
            android:elevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_avatar_cat"
                android:padding="5dp">
            </ImageView>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_student_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Student name"
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/deep_wood"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="92dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_student_form"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Form 4"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.08"
            android:background="@drawable/shape_pill_brown"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="92dp"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_student_name"
            app:layout_constraintStart_toStartOf="parent">
        </TextView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="92dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_student_form"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_coin_bell"
                android:scaleType="fitCenter"
                android:layout_marginEnd="5dp">
            </ImageView>

            <TextView
                android:id="@+id/tv_student_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Bells"
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@color/wood_brown"
                android:fontFamily="@font/nunito_bold">
            </TextView>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_chevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="30dp"
            android:textStyle="bold"
            android:textColor="@color/cork_tan"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
