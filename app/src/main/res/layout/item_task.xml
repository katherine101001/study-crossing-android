<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cream_paper">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_paper"
        android:minHeight="80dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/fl_subject_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/shape_avatar_circle"
            android:layout_marginStart="14dp"
            android:elevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_subject_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_npc_tanuki_normal"
                android:padding="4dp">
            </ImageView>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Task title here"
            android:textSize="15dp"
            android:textStyle="bold"
            android:textColor="@color/deep_wood"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="1dp"
            android:layout_marginStart="82dp"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_task_subject"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed">
        </TextView>

        <TextView
            android:id="@+id/tv_task_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Math"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.12"
            android:background="@drawable/shape_subject_chip_math"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="82dp"
            android:layout_marginTop="7dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_task_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_notes_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add Note"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.04"
            android:background="@drawable/shape_pill_green"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintStart_toEndOf="@id/tv_task_subject"
            app:layout_constraintTop_toTopOf="@id/tv_task_subject"
            app:layout_constraintBottom_toBottomOf="@id/tv_task_subject">
        </TextView>

        <ImageView
            android:id="@+id/iv_done_stamp"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_stamp_done"
            android:scaleType="fitCenter"
            android:alpha="0.95"
            android:rotation="-12"
            android:visibility="gone"
            android:layout_marginEnd="14dp"
            android:elevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </ImageView>

        <TextView
            android:id="@+id/tv_chevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="30dp"
            android:textStyle="bold"
            android:textColor="@color/cork_tan"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
