<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cream_paper">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cream_paper"
        android:minHeight="84dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/fl_teacher_avatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/shape_avatar_circle"
            android:layout_marginStart="16dp"
            android:elevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_npc_owl_normal"
                android:padding="6dp">
            </ImageView>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_teacher_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="teacher username"
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/deep_wood"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="92dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/nunito_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_teacher_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teacher"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.08"
            android:background="@drawable/shape_pill_brown"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="92dp"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintTop_toBottomOf="@id/tv_teacher_name"
            app:layout_constraintStart_toStartOf="parent">
        </TextView>

        <TextView
            android:id="@+id/tv_teacher_remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove"
            android:textSize="12dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/shape_pill_red"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="18dp"
            android:fontFamily="@font/fredoka_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
